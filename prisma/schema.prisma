generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model EducationStage {
  id     String  @id @default(uuid())
  name   String
  grades Grade[]
}

model Grade {
  id        String         @id @default(uuid())
  name      String
  stageId   String
  stage     EducationStage @relation(fields: [stageId], references: [id])
  subjects  Subject[]
}

model Subject {
  id      String   @id @default(uuid())
  name    String
  gradeId String
  grade   Grade    @relation(fields: [gradeId], references: [id])
  books   Book[]
  lessons Lesson[]
}

model Book {
  id         String  @id @default(uuid())
  title      String
  term       String
  fileUrl    String
  fileSizeMb Float
  subjectId  String
  subject    Subject @relation(fields: [subjectId], references: [id])
}

model Lesson {
  id        String  @id @default(uuid())
  title     String
  term      String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])
}

model AiContent {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
}